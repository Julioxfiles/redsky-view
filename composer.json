{
  "name": "redsky/view",
  "description": "RedSky View Component Library",
  "type": "library",
  "license": "proprietary",

  "require": {
    "php": ">=8.1",
    "redsky/framework": "dev-main"
  },

  "repositories": [
    {
      "type": "path",
      "url": "../redsky-framework",
      "options": {
        "symlink": true
      }
    }
  ],

  "autoload": {
    "psr-4": {
      "RedSky\\View\\": "src/"
    },
    "files": [
      "src/Support/helpers.php"
    ]
  },

  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },

  "minimum-stability": "dev",
  "prefer-stable": true
}